# Copy to .env and fill in. NEVER commit .env.

# --- Database (Postgres — Neon/Supabase free tier; must be reachable by fonio's cloud) ---
# Pooled connection string (app runtime). Neon: ...-pooler.../db?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"
# Direct (non-pooled) connection for `prisma migrate`. Leave blank to reuse DATABASE_URL.
DIRECT_URL=""

# --- fonio.ai (from the provisioned hackathon account; see account API docs) ---
FONIO_API_KEY=""
FONIO_API_BASE_URL="https://app.fonio.ai"
FONIO_ASSISTANT_ID=""           # the outbound assistant to use, if applicable
FONIO_WEBHOOK_SECRET=""         # to verify inbound API Request / webhook calls

# Public URL of your dev server for fonio webhooks (e.g. from `ngrok http 3000`)
PUBLIC_BASE_URL=""

# --- Live demo phones (real numbers, WITH consent) ---
DEMO_PHONE_1=""                 # EV winner — answers YES on the happy-path call
DEMO_PHONE_2=""                 # no-answer edge case — let it ring out
DEMO_PHONE_3=""                 # spare / no-consent demo patient

# --- LLM for the "why this patient" rationale (optional) ---
ANTHROPIC_API_KEY=""
