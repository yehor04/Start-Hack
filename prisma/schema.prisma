// Refill — unified data model (Olha's richer ranker fields adopted).
// SQLite for hack speed. The waitlist = Patient rows with onWaitlist = true.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Patient {
  id    String @id @default(cuid())
  name  String
  phone String
  age   Int?

  consentOutbound Boolean @default(true) // GDPR hard gate
  onWaitlist      Boolean @default(true) // the waitlist = active patients

  // clinical + waitlist signals (drive the ranker)
  urgency           String   @default("routine") // urgent | moderate | routine
  condition         String   @default("")
  assignedDoctor    String   @default("")
  timePreference    String   @default("flexible") // morning | afternoon | flexible
  preferredTime     String   @default("09:00") // "HH:MM"
  daysOnWaitlist    Int      @default(0)
  assignedDate      DateTime @default(now())
  contactAttempts   Int      @default(0)
  lastContactResult String   @default("none") // none | voicemail | no_answer | declined
  timesSkipped      Int      @default(0)
  procedureCost     Int      @default(0) // KPI only — NOT in the score
  procedureTimeMin  Int      @default(30)

  createdAt DateTime @default(now())
  attempts  RecoveryAttempt[]
}

model Slot {
  id                String   @id @default(cuid())
  startsAt          DateTime
  durationMin       Int      @default(60)
  treatment         String // display label
  practitioner      String? // = doctor; must match Patient.assignedDoctor
  room              String?
  status            String   @default("open") // booked | cancelled | open | filling | filled
  valueEur          Int      @default(0)
  bookedPatientName String? // occupant of a booked slot (existing schedule)
  recoveredBy       String? // who refilled it via Refill
  createdAt         DateTime @default(now())

  attempts RecoveryAttempt[]
}

model RecoveryAttempt {
  id        String  @id @default(cuid())
  slotId    String
  slot      Slot    @relation(fields: [slotId], references: [id])
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  status String @default("queued") // queued|calling|yes|no|no_answer|voicemail|callback|failed

  score          Float
  pAccept        Float?
  evEur          Float?
  scoreBreakdown String // JSON of per-factor contributions
  reasonText     String?

  fonioCallId    String?
  idempotencyKey String   @unique
  createdAt      DateTime @default(now())
  resolvedAt     DateTime?

  @@unique([slotId, patientId])
}

model EventLog {
  id        String   @id @default(cuid())
  type      String
  slotId    String?
  patientId String?
  attemptId String?
  payload   String
  createdAt DateTime @default(now())
}
